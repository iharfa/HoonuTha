# Neon Postgres connection string — enables the shared online dataset so every
# child's readings pool together. Copy this file to .env.local for local dev.
# On Vercel, set DATABASE_URL as an environment variable (added automatically if
# you use the Neon integration from the Vercel marketplace).
#
# Without this, the app falls back to a local JSON file (data/db.json) — fine
# for a single machine, but it does NOT persist on serverless hosts like Vercel.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Public site origin, used to build absolute Open Graph image URLs.
NEXT_PUBLIC_SITE_URL=https://your-domain.example
